{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3Access",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:ListBucket",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::[YOUR_S3_BUCKET]",
                "arn:aws:s3:::[YOUR_S3_BUCKET]/*"
            ]
        },
        {
            "Sid": "CFAccess",
            "Effect": "Allow",
            "Action": [
                "cloudfront:CreateInvalidation"
            ],
            "Resource": "arn:aws:cloudfront::*:distribution/[CLOUDFRONT]"
        }
    ]
}